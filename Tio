<!DOCTYPE html>
<html lang="ar">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>🔥 Tic Tac Toe Telegram PRO</title>

<!-- ✅ MONETAG SDK (مهم جدا داخل head) -->
<script src='//libtl.com/sdk.js' data-zone='10990911' data-sdk='show_10990911'></script>

<style>
body {
  background:#0f172a;
  color:white;
  font-family:Arial;
  text-align:center;
}

h1 {color:#38bdf8;}

.board {
  display:grid;
  grid-template-columns:repeat(3,90px);
  gap:6px;
  justify-content:center;
  margin:20px auto;
}

.cell {
  width:90px;height:90px;
  background:#1e293b;
  display:flex;
  align-items:center;
  justify-content:center;
  font-size:2rem;
  cursor:pointer;
}

.x {color:#38bdf8;}
.o {color:#f43f5e;}

button {
  margin:5px;
  padding:10px;
  border:none;
  cursor:pointer;
  border-radius:6px;
}

.ad-btn {
  background:#22c55e;
  color:white;
  font-weight:bold;
}
</style>
</head>

<body>

<h1>🔥 Tic Tac Toe PRO</h1>

<p id="status">🎮 دور اللاعب X</p>
<p>💰 Coins: <span id="coins">0</span></p>

<!-- 🎯 AI LEVEL -->
<h3>🎯 اختر المستوى</h3>
<button onclick="setDifficulty('easy')">😄 سهل</button>
<button onclick="setDifficulty('medium')">😐 متوسط</button>
<button onclick="setDifficulty('hard')">😈 صعب</button>

<div class="board" id="board"></div>

<!-- 🎁 ADS -->
<button class="ad-btn" onclick="watchAdCoins()">
🎁 اضغط هنا لمشاهدة إعلان واربح Coins 💰
</button>

<br>

<button onclick="watchAdRestart()">🎮 إعادة اللعب (بإعلان)</button>

<h3>🛒 المتجر</h3>
<button onclick="buyExtraMove()">⚡ حركة إضافية (5 Coins)</button>

<script>
// ===== VARIABLES =====
let board = document.getElementById("board");
let statusText = document.getElementById("status");
let coinsText = document.getElementById("coins");

let gameState = Array(9).fill(null);
let currentPlayer = "X";
let coins = 0;
let difficulty = "easy";
let extraMoveActive = false;

// ===== INIT =====
function init(){
  board.innerHTML="";
  gameState = Array(9).fill(null);

  for(let i=0;i<9;i++){
    let cell=document.createElement("div");
    cell.classList.add("cell");
    cell.onclick=()=>move(i);
    board.appendChild(cell);
  }
}
init();

// ===== AUTO ADS (In-App) =====
window.onload = function() {
  show_10990911({
    type: 'inApp',
    inAppSettings: {
      frequency: 2,
      capping: 0.1,
      interval: 30,
      timeout: 5,
      everyPage: false
    }
  });
};

// ===== MOVE =====
function move(i){
  if(gameState[i]) return;

  gameState[i]=currentPlayer;
  board.children[i].textContent=currentPlayer;
  board.children[i].classList.add(currentPlayer.toLowerCase());

  if(checkWinner()){
    statusText.textContent="🎉 اللاعب "+currentPlayer+" فاز!";

    setTimeout(()=>{
      if(confirm("💀 خسرت! تريد فرصة ثانية؟ شاهد إعلان 🎁")){
        show_10990911().then(()=>restart());
      }
    },300);

    return;
  }

  if(!gameState.includes(null)){
    statusText.textContent="🤝 تعادل!";
    return;
  }

  if(extraMoveActive){
    extraMoveActive=false;
    alert("⚡ حركة إضافية!");
    return;
  }

  currentPlayer = currentPlayer==="X"?"O":"X";
  statusText.textContent="🎮 دور اللاعب "+currentPlayer;

  if(currentPlayer==="O"){
    setTimeout(aiMove,500);
  }
}

// ===== AI =====
function aiMove(){
  let empty = gameState.map((v,i)=>v===null?i:null).filter(v=>v!==null);
  let move;

  if(difficulty==="easy"){
    move = empty[Math.floor(Math.random()*empty.length)];
  }
  else if(difficulty==="medium"){
    move = empty.includes(4)?4:empty[Math.floor(Math.random()*empty.length)];
  }
  else if(difficulty==="hard"){
    move = bestMove();
  }

  if(move!==undefined) movePlay(move);
}

function movePlay(i){ move(i); }

// ===== HARD AI =====
function bestMove(){
  let bestScore=-Infinity;
  let move;

  gameState.forEach((val,i)=>{
    if(val===null){
      gameState[i]="O";
      let score=minimax(gameState,false);
      gameState[i]=null;
      if(score>bestScore){
        bestScore=score;
        move=i;
      }
    }
  });
  return move;
}

function minimax(state,isMax){
  let winner = getWinner(state);
  if(winner==="O") return 1;
  if(winner==="X") return -1;
  if(!state.includes(null)) return 0;

  if(isMax){
    let best=-Infinity;
    state.forEach((v,i)=>{
      if(v===null){
        state[i]="O";
        best=Math.max(best,minimax(state,false));
        state[i]=null;
      }
    });
    return best;
  } else {
    let best=Infinity;
    state.forEach((v,i)=>{
      if(v===null){
        state[i]="X";
        best=Math.min(best,minimax(state,true));
        state[i]=null;
      }
    });
    return best;
  }
}

// ===== WIN =====
function checkWinner(){
  return getWinner(gameState);
}

function getWinner(state){
  const w=[[0,1,2],[3,4,5],[6,7,8],[0,3,6],[1,4,7],[2,5,8],[0,4,8],[2,4,6]];
  for(let [a,b,c] of w){
    if(state[a] && state[a]===state[b] && state[a]===state[c]){
      return state[a];
    }
  }
  return null;
}

// ===== ADS =====
function watchAdCoins(){
  alert("🔥 شاهد الإعلان للنهاية لتحصل على Coins!");

  show_10990911().then(()=>{
    coins+=10;
    updateCoins();
    alert("💰 مبروك! حصلت على 10 Coins!");
  }).catch(()=>{
    alert("⚠️ الإعلان لم يعمل");
  });
}

function watchAdRestart(){
  show_10990911().then(()=>restart());
}

// ===== COINS =====
function updateCoins(){
  coinsText.textContent=coins;
}

// ===== SHOP =====
function buyExtraMove(){
  if(coins>=5){
    coins-=5;
    extraMoveActive=true;
    updateCoins();
    alert("⚡ تم تفعيل حركة إضافية!");
  } else {
    alert("❌ لا توجد Coins كافية");
  }
}

// ===== SETTINGS =====
function setDifficulty(d){
  difficulty=d;
  alert("🎯 المستوى: "+d);
  restart();
}

// ===== RESTART =====
function restart(){
  currentPlayer="X";
  statusText.textContent="🎮 دور اللاعب X";
  init();
}
</script>

</body>
</html>
